[Unit]
Description=OpenCode Server
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
User=$DEV_USER
WorkingDirectory=$DEV_HOME

Environment=HOME=$DEV_HOME
Environment=PATH=$DEV_HOME/.local/bin:$DEV_HOME/.bun/bin:$DEV_HOME/.opencode/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

ExecStart=$DEV_HOME/.opencode/bin/opencode serve --hostname 127.0.0.1 --port 4096

StandardOutput=journal
StandardError=journal

Restart=on-failure
RestartSec=10
TimeoutStartSec=60
TimeoutStopSec=30
MemoryMax=2G
TasksMax=256
RateLimitIntervalSec=30
RateLimitBurst=500

[Install]
WantedBy=multi-user.target
