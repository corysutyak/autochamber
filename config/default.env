# OpenCode model configuration
# Copy this file to config/.env and edit for your deployment.
# The install script reads config/.env to fill in the config template.

# Main model used by the build agent and general tasks
OPENCODE_MODEL=openai/gpt-5.2-codex

# Smaller, faster model for title generation and lightweight tasks
OPENCODE_SMALL_MODEL=openai/gpt-5.2

# --- Custom OpenAI-compatible provider (optional) ---
# Set to "true" to inject a custom provider block into the config.
# Models are auto-discovered at runtime via opencode-models-discovery plugin.
# When enabled, PROVIDER_URL is required; PROVIDER_API_KEY is optional.
OPENCODE_CUSTOM_PROVIDER=false

# Base URL for the custom OpenAI-compatible provider (e.g., http://llama.local/v1)
OPENCODE_PROVIDER_URL=

# API key for the custom provider (leave empty if not needed)
OPENCODE_PROVIDER_API_KEY=

# --- Swarm-tools embeddings (Ollama) ---
# Ollama is installed automatically. Change model if desired.
# Supported: mxbai-embed-large (1024d), nomic-embed-text (768d), all-minilm (384d)
OLLAMA_MODEL=nomic-embed-text
OLLAMA_HOST=http://localhost:11434

# --- Agent identity (git) ---
# Git identity used by agents for commits and push operations.
AGENT_NAME="OpenChamber Agent"
AGENT_EMAIL=agent@localvm

# --- GitHub CLI authentication (optional) ---
# Set your GitHub personal access token to auto-auth gh during install.
# Generate at: https://github.com/settings/tokens
GH_TOKEN=
